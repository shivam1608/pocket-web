---
interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const navItems = [
  { label: "~/home", href: "/" },
  { label: "~/why-esp", href: "/why" },
  { label: "~/how", href: "/how" },
];
---

<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 w-52 bg-[#080808] border-r border-[#1c1c1c] flex flex-col z-40"
  style="transform: translateX(-100%); transition: transform 0.25s ease;"
>
  <!-- Nav -->
  <nav class="flex-1 px-3 py-6 space-y-0.5">
    {
      navItems.map((item) => (
        <a
          href={item.href}
          class={`flex items-center px-3 py-2.5 text-xl rounded tracking-wider transition-colors duration-150 ${
            currentPath === item.href
              ? "text-[#c8ff00] bg-[#131300]"
              : "text-[#555] hover:text-[#c8ff00] hover:bg-[#111]"
          }`}
        >
          {item.label}
        </a>
      ))
    }
  </nav>

  <!-- Footer -->
  <div class="px-5 py-4 border-t border-[#181818] flex flex-col gap-4">
    <a
      href="https://github.com/shivam1608"
      target="_blank"
      rel="noopener noreferrer"
      class="text-[#555] hover:text-[#c8ff00] transition-colors flex items-center gap-3 w-fit"
      aria-label="GitHub Profile"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"
        ></path>
      </svg>
      <span class="text-xl tracking-wider">github</span>
    </a>
    <div class="text-[#2a2a2a] text-base tracking-widest">esp32 // online</div>
  </div>
</aside>

<!-- Mobile topbar -->
<header
  class="fixed top-0 left-0 right-0 h-11 bg-[#080808] border-b border-[#1c1c1c] flex items-center px-4 z-30 md:hidden"
>
  <button
    id="menu-btn"
    aria-label="Toggle menu"
    class="text-[#555] hover:text-[#c8ff00] transition-colors mr-3 p-1"
  >
    <svg
      class="w-5 h-5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      stroke-width="1.5"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
    </svg>
  </button>
  <!-- <span class="text-[#c8ff00] text-2xl tracking-widest">shivzee</span> -->
</header>

<!-- Overlay -->
<div id="overlay" class="fixed inset-0 bg-black/60 z-30 hidden md:hidden"></div>

<script>
  const btn = document.getElementById("menu-btn") as HTMLButtonElement | null;
  const sidebar = document.getElementById("sidebar") as HTMLElement | null;
  const overlay = document.getElementById("overlay") as HTMLElement | null;

  const openSidebar = () => {
    sidebar?.style.setProperty("transform", "translateX(0)");
    overlay?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  };
  const closeSidebar = () => {
    sidebar?.style.setProperty("transform", "translateX(-100%)");
    overlay?.classList.add("hidden");
    document.body.style.overflow = "";
  };

  btn?.addEventListener("click", () => {
    const isOpen =
      sidebar?.style.transform === "translateX(0px)" ||
      sidebar?.style.transform === "translateX(0)";
    isOpen ? closeSidebar() : openSidebar();
  });
  overlay?.addEventListener("click", closeSidebar);

  const mq = window.matchMedia("(min-width: 768px)");
  const handleBreakpoint = (e: MediaQueryList | MediaQueryListEvent) => {
    if (e.matches) {
      sidebar?.style.setProperty("transform", "translateX(0)");
      overlay?.classList.add("hidden");
      document.body.style.overflow = "";
    } else {
      sidebar?.style.setProperty("transform", "translateX(-100%)");
    }
  };
  handleBreakpoint(mq);
  mq.addEventListener("change", handleBreakpoint);
</script>
